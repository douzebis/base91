#compdef base91

autoload -U is-at-least

_base91() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-o+[Write output to FILE instead of standard output.]:FILE:_files' \
'--output=[Write output to FILE instead of standard output.]:FILE:_files' \
'-m+[Use SIZE bytes of memory for I/O buffers (suffixes\: b, K, M). Default\: 64K.]:SIZE:_default' \
'--buffer=[Use SIZE bytes of memory for I/O buffers (suffixes\: b, K, M). Default\: 64K.]:SIZE:_default' \
'-w+[Wrap encoded lines after COLS characters (0 = no wrap; default 76). With --simd, COLS must be a multiple of 32. Has no effect when decoding.]:COLS:_default' \
'--wrap=[Wrap encoded lines after COLS characters (0 = no wrap; default 76). With --simd, COLS must be a multiple of 32. Has no effect when decoding.]:COLS:_default' \
'-d[Decode data instead of encoding.]' \
'--decode[Decode data instead of encoding.]' \
'*-v[Print statistics to stderr. Repeat (-vv) for extra verbosity.]' \
'*--verbose[Print statistics to stderr. Repeat (-vv) for extra verbosity.]' \
'--simd[Use the SIMD fixed-width variant for encoding. Output begins with '\''-'\'' and uses the SIMD alphabet (0x23-0x26, 0x28-0x7E); not compatible with legacy Henke decoders. Ignored when decoding.]' \
'-h[Print help (see more with '\''--help'\'')]' \
'--help[Print help (see more with '\''--help'\'')]' \
'-V[Print version]' \
'--version[Print version]' \
'::file -- Input file (default\: stdin).:_files' \
&& ret=0
}

(( $+functions[_base91_commands] )) ||
_base91_commands() {
    local commands; commands=()
    _describe -t commands 'base91 commands' commands "$@"
}

if [ "$funcstack[1]" = "_base91" ]; then
    _base91 "$@"
else
    compdef _base91 base91
fi
